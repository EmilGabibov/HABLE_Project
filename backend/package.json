{
  "name": "hable-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup:doppler": "doppler setup",
    "sync:pages-secrets": "node scripts/sync-pages-secrets.mjs",
    "dev": "doppler run -- wrangler pages dev public --port 8787",
    "deploy": "wrangler pages deploy public --project-name hable",
    "web:build": "cd .. && flutter build web --release --base-href /",
    "web:deploy": "cd .. && flutter build web --release --base-href / && wrangler pages deploy ../build/web --project-name hable --branch main --commit-dirty=true --cwd backend",
    "db:setup": "wrangler d1 execute hable_db --local --file=./schema.sql",
    "smoke:lifecycle": "node scripts/lifecycle-smoke.mjs",
    "smoke:social": "node scripts/social-friend-smoke.mjs",
    "smoke:regression": "node scripts/account-social-regression-smoke.mjs"
  },
  "dependencies": {
    "hono": "^4.2.1",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "typescript": "^5.4.4",
    "wrangler": "^4.111.0"
  }
}
