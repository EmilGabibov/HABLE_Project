#include "../../Flutter/Flutter-Release.xcconfig"
#include "Warnings.xcconfig"

// Protected values are injected by the Developer ID/App Store operator.
MACOS_DEVELOPMENT_TEAM = __INJECT_MACOS_DEVELOPMENT_TEAM__
MACOS_CODE_SIGN_IDENTITY = Developer ID Application
MACOS_PROVISIONING_PROFILE_SPECIFIER = __INJECT_MACOS_PROVISIONING_PROFILE__
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = $(MACOS_CODE_SIGN_IDENTITY)
DEVELOPMENT_TEAM = $(MACOS_DEVELOPMENT_TEAM)
PROVISIONING_PROFILE_SPECIFIER = $(MACOS_PROVISIONING_PROFILE_SPECIFIER)
ENABLE_HARDENED_RUNTIME = YES

// Local `flutter build macos --release` is compile-only by default. Protected
// archive commands must pass CODE_SIGNING_ALLOWED=YES explicitly.
CODE_SIGNING_ALLOWED = NO
CODE_SIGNING_REQUIRED = NO
